# --- secrets（絶対にコミットしない） ---
.env
**/.env
lp/.env

# --- Python ---
__pycache__/
*.pyc
*.pyo

# --- 生成物（generate_*.py と Edge で再生成できる） ---
output/

# --- Node / ビルド ---
node_modules/
lp/node_modules/
dist/

# --- OS / エディタ ---
.DS_Store
Thumbs.db
*.swp

# --- 作業用バックアップ（画像の作り直し前の退避） ---
assets/_backup_smalltext/
assets/_backup_new5/
assets/reference/*-prefix.webp
assets/_*-old.webp

# 作業用一時データ
tmp/

# --- 歴史クエストの画像 ---
# PNG は Codex(image_generation) が出す原本で1枚1MB前後。配信するのは
# tools/quest_assets_to_webp.py が作る .webp だけなので、PNG は追跡しない。
# カンプ（デザインの正本）だけは残す。
assets/quest/*.png
!assets/quest/quest-top-mobile.png

# ブラウザ自動操作の使い捨てプロファイル
.edge-*/

# 出力・プレビュー・バックアップ・スクラッチ（再生成可能／git不要）
covers/out/
mascot-preview/
assets/_backup_answers/
scratch_*.log
